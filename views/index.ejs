<!DOCTYPE html>
<html lang="tr" class="dark h-full">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Türkiye Deprem Takip Sistemi</title>
    
    <!-- Tailwind CSS -->
    <link rel="stylesheet" href="/css/style.css">
    
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
    
    <!-- Custom CSS -->
    <link rel="stylesheet" type="text/css" href="/assets/css/style.css">
    <link rel="stylesheet" type="text/css" href="/assets/css/stats.css">
    <link rel="stylesheet" type="text/css" href="/assets/css/map.css">
</head>

<body class="bg-gray-100 dark:bg-gray-900 font-sans min-h-full">
    <!-- Navbar -->
    <nav class="bg-white dark:bg-gray-800 shadow-lg h-16">
        <div class="max-w-full mx-auto px-4 h-full">
            <div class="flex justify-between items-center h-full">
                <div class="flex items-center">
                    <h1 class="text-xl font-bold text-gray-800 dark:text-white">Türkiye Deprem Takip Sistemi</h1>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="flex flex-col min-h-screen">
        <!-- İçerik Alanı -->
        <div class="flex-1 flex flex-col p-4 gap-4">
            <!-- Harita (üstte tam genişlik) -->
            <div class="w-full h-96 bg-white dark:bg-gray-800 rounded-lg shadow-lg overflow-hidden mb-4">
                <div id="map" class="w-full h-full"></div>
            </div>

            <!-- Alt Panel: Deprem Listesi ve İstatistik Kartları -->
            <div class="flex-1 flex flex-col lg:flex-row gap-4">
                <!-- Sol Sütun - Deprem Listesi -->
                <div class="w-full lg:w-1/2 flex flex-col">
                    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg overflow-hidden flex-1 flex flex-col">
                        <!-- Başlık ve Otomatik Güncelleme -->
                        <div class="p-4 border-b dark:border-gray-700 flex justify-between items-center flex-wrap gap-2">
                            <h2 class="text-xl font-bold text-gray-900 dark:text-white">Akıllı Deprem Listesi</h2>
                            <div class="flex items-center gap-4">
                                <div class="text-sm text-gray-500 dark:text-gray-400">
                                    Güncelleme: <span id="countdown">120</span>s
                                </div>
                                <div class="flex items-center gap-2">
                                    <select id="updateFrequency" class="px-3 py-1 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-600 dark:border-gray-500 dark:text-white text-sm">
                                        <option value="120">120 saniye</option>
                                        <option value="300">300 saniye</option>
                                        <option value="600">600 saniye</option>
                                    </select>
                                </div>
                                <div class="flex items-center">
                                    <div class="relative inline-block w-14 h-8">
                                        <input type="checkbox" id="autoUpdate" class="sr-only" checked>
                                        <div class="block bg-gray-300 w-14 h-8 rounded-full transition-colors duration-200 ease-in-out"></div>
                                        <div class="dot absolute left-1 top-1 bg-white w-6 h-6 rounded-full transition-transform duration-200 ease-in-out"></div>
                                    </div>
                                    <label for="autoUpdate" class="ml-3 block text-sm font-medium text-gray-700 dark:text-gray-300 cursor-pointer">Otomatik Güncelle</label>
                                </div>
                            </div>
                        </div>

                        <!-- Filtreler -->
                        <div class="p-4 border-b dark:border-gray-700 bg-gray-50 dark:bg-gray-700/30">
                            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                                <!-- Şehir Filtresi -->
                                <div>
                                    <label for="cityFilter" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Şehir</label>
                                    <select id="cityFilter" class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-600 dark:border-gray-500 dark:text-white">
                                        <option value="">Tüm Şehirler</option>
                                    </select>
                                </div>
                                
                                <!-- Büyüklük Filtresi -->
                                <div>
                                    <label for="magnitudeFilter" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                        Büyüklük (Min): <span id="magnitudeValue" class="text-blue-600 font-semibold">0.0</span>
                                    </label>
                                    <input type="range" id="magnitudeFilter" min="0" max="10" step="0.1" value="0" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer dark:bg-gray-700 slider">
                                </div>
                                
                                <!-- Derinlik Filtresi -->
                                <div>
                                    <label for="depthFilter" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                                        Derinlik (Max km): <span id="depthValue" class="text-blue-600 font-semibold">100</span>
                                    </label>
                                    <input type="range" id="depthFilter" min="0" max="100" step="1" value="100" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer dark:bg-gray-700 slider">
                                </div>
                                
                                <!-- Temizle Butonu -->
                                <div class="flex items-end">
                                    <button id="clearFilters" class="w-full px-4 py-2 bg-gray-600 text-white rounded-md hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 dark:bg-gray-500 dark:hover:bg-gray-600 dark:focus:ring-gray-400">
                                        Filtreleri Temizle
                                    </button>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Deprem Tablosu -->
                        <div class="flex-1 overflow-auto custom-scrollbar">
                            <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                                <thead class="bg-gray-50 dark:bg-gray-700/50 sticky top-0">
                                    <tr>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Tarih/Saat</th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Büyüklük</th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Derinlik</th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Yer</th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Şehir</th>
                                    </tr>
                                </thead>
                                <tbody id="quakeList" class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                                    <!-- JavaScript ile doldurulacak -->
                                </tbody>
                            </table>
                        </div>
                        
                        <!-- Sayfalama -->
                        <div class="p-4 border-t dark:border-gray-700 flex justify-between items-center">
                            <div id="pagination-info" class="text-sm text-gray-600 dark:text-gray-400">
                                <!-- Sayfa 1 / 10 -->
                            </div>
                            <div class="flex gap-2">
                                <button id="prevPage" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600">Önceki</button>
                                <button id="nextPage" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600">Sonraki</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sağ Sütun - İstatistik Kartları -->
                <div class="w-full lg:w-1/2 flex flex-col">
                    <div class="stats-container space-y-4">
                        <div class="stats-card p-6 cursor-pointer bg-white dark:bg-gray-800 rounded-lg shadow-lg" id="last-24-hours">
                            <div class="flex items-start justify-between">
                                <div class="flex-1">
                                    <div class="icon-container icon-primary dark:bg-gray-700">
                                        📊
                                    </div>
                                    <div class="stats-title text-gray-800 dark:text-gray-200">Son 24 Saat Aktivitesi</div>
                                    <div class="flex flex-wrap justify-between items-start mb-2 gap-x-4 gap-y-2">
                                        <div>
                                            <div class="counter-value text-3xl font-bold text-gray-900 dark:text-white">
                                                <span id="counter-24h">0</span>
                                            </div>
                                            <div class="stats-subtitle text-gray-600 dark:text-gray-400">Toplam Deprem</div>
                                        </div>
                                        <div class="flex flex-col gap-2 text-sm text-right">
                                            <div class="flex items-center justify-end gap-2 text-gray-700 dark:text-gray-300">
                                                <span class="text-lg">☀️</span>
                                                <div>
                                                    <span id="counter-24h-day" class="font-bold">0</span>
                                                    <span class="text-xs">Gündüz</span>
                                                </div>
                                            </div>
                                            <div class="flex items-center justify-end gap-2 text-gray-700 dark:text-gray-300">
                                                <span class="text-lg">🌙</span>
                                                <div>
                                                    <span id="counter-24h-night" class="font-bold">0</span>
                                                    <span class="text-xs">Gece</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="hourly-bars grid grid-cols-6 gap-1 mt-2">
                                        <div class="hourly-bar">
                                            <div class="text-xs text-center mb-1">🌙 0-4</div>
                                            <div id="hourly-0" class="h-12 bg-gray-100 dark:bg-gray-700 rounded flex items-center justify-center font-medium text-gray-800 dark:text-gray-200">0</div>
                                        </div>
                                        <div class="hourly-bar">
                                            <div class="text-xs text-center mb-1">🌅 4-8</div>
                                            <div id="hourly-4" class="h-12 bg-gray-100 dark:bg-gray-700 rounded flex items-center justify-center font-medium text-gray-800 dark:text-gray-200">0</div>
                                        </div>
                                        <div class="hourly-bar">
                                            <div class="text-xs text-center mb-1">☀️ 8-12</div>
                                            <div id="hourly-8" class="h-12 bg-gray-100 dark:bg-gray-700 rounded flex items-center justify-center font-medium text-gray-800 dark:text-gray-200">0</div>
                                        </div>
                                        <div class="hourly-bar">
                                            <div class="text-xs text-center mb-1">🌞 12-16</div>
                                            <div id="hourly-12" class="h-12 bg-gray-100 dark:bg-gray-700 rounded flex items-center justify-center font-medium text-gray-800 dark:text-gray-200">0</div>
                                        </div>
                                        <div class="hourly-bar">
                                            <div class="text-xs text-center mb-1">🌇 16-20</div>
                                            <div id="hourly-16" class="h-12 bg-gray-100 dark:bg-gray-700 rounded flex items-center justify-center font-medium text-gray-800 dark:text-gray-200">0</div>
                                        </div>
                                        <div class="hourly-bar">
                                            <div class="text-xs text-center mb-1">🌙 20-24</div>
                                            <div id="hourly-20" class="h-12 bg-gray-100 dark:bg-gray-700 rounded flex items-center justify-center font-medium text-gray-800 dark:text-gray-200">0</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="stats-card p-6 cursor-pointer" id="magnitude-distribution">
                            <div class="flex items-start justify-between">
                                <div class="flex-1">
                                    <div class="icon-container icon-warning">
                                        ⚡
                                    </div>
                                    <div class="stats-title">Büyüklük Dağılımı</div>
                                    <div class="flex flex-wrap justify-between items-start mb-2 gap-x-4 gap-y-2">
                                        <div>
                                            <div class="counter-value text-3xl font-bold text-gray-900 dark:text-white">
                                                <span id="counter-magnitude">0.0</span>
                                            </div>
                                            <div class="stats-subtitle text-gray-600 dark:text-gray-400">Ortalama</div>
                                        </div>
                                        <div class="text-right">
                                            <div class="flex items-center justify-end gap-1 text-sm font-semibold text-gray-600 dark:text-gray-400">
                                                <span class="text-base">🏆</span>
                                                <span>Max:</span>
                                                <span id="max-magnitude">0.0</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="magnitude-bars grid grid-cols-6 gap-1 mt-2">
                                        <div class="magnitude-bar">
                                            <div class="text-xs text-center mb-1">1-2</div>
                                            <div class="h-12 bg-gray-100 dark:bg-gray-700 rounded relative overflow-hidden">
                                                <div id="magnitude-1-2" class="absolute bottom-0 w-full bg-yellow-200 dark:bg-yellow-600" style="height: 0%"></div>
                                            </div>
                                            <div id="magnitude-1-2-count" class="text-xs text-center mt-1">0</div>
                                        </div>
                                        <div class="magnitude-bar">
                                            <div class="text-xs text-center mb-1">2-3</div>
                                            <div class="h-12 bg-gray-100 dark:bg-gray-700 rounded relative overflow-hidden">
                                                <div id="magnitude-2-3" class="absolute bottom-0 w-full bg-yellow-300 dark:bg-yellow-500" style="height: 0%"></div>
                                            </div>
                                            <div id="magnitude-2-3-count" class="text-xs text-center mt-1">0</div>
                                        </div>
                                        <div class="magnitude-bar">
                                            <div class="text-xs text-center mb-1">3-4</div>
                                            <div class="h-12 bg-gray-100 dark:bg-gray-700 rounded relative overflow-hidden">
                                                <div id="magnitude-3-4" class="absolute bottom-0 w-full bg-orange-300 dark:bg-orange-500" style="height: 0%"></div>
                                            </div>
                                            <div id="magnitude-3-4-count" class="text-xs text-center mt-1">0</div>
                                        </div>
                                        <div class="magnitude-bar">
                                            <div class="text-xs text-center mb-1">4-5</div>
                                            <div class="h-12 bg-gray-100 dark:bg-gray-700 rounded relative overflow-hidden">
                                                <div id="magnitude-4-5" class="absolute bottom-0 w-full bg-orange-400 dark:bg-orange-600" style="height: 0%"></div>
                                            </div>
                                            <div id="magnitude-4-5-count" class="text-xs text-center mt-1">0</div>
                                        </div>
                                        <div class="magnitude-bar">
                                            <div class="text-xs text-center mb-1">5-6</div>
                                            <div class="h-12 bg-gray-100 dark:bg-gray-700 rounded relative overflow-hidden">
                                                <div id="magnitude-5-6" class="absolute bottom-0 w-full bg-red-400 dark:bg-red-600" style="height: 0%"></div>
                                            </div>
                                            <div id="magnitude-5-6-count" class="text-xs text-center mt-1">0</div>
                                        </div>
                                        <div class="magnitude-bar">
                                            <div class="text-xs text-center mb-1">6+</div>
                                            <div class="h-12 bg-gray-100 dark:bg-gray-700 rounded relative overflow-hidden">
                                                <div id="magnitude-6plus" class="absolute bottom-0 w-full bg-red-500 dark:bg-red-700" style="height: 0%"></div>
                                            </div>
                                            <div id="magnitude-6plus-count" class="text-xs text-center mt-1">0</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="stats-card p-6 cursor-pointer" id="deepest-earthquake">
                            <div class="flex items-start justify-between">
                                <div class="flex-1">
                                    <div class="icon-container icon-secondary">
                                        🔍
                                    </div>
                                    <div class="stats-title">Derinlik Dağılımı</div>
                                    <div class="flex justify-between items-center mb-2">
                                        <div class="text-center">
                                            <div class="text-xs text-gray-600 dark:text-gray-400">En Derin</div>
                                            <div class="counter-value text-lg font-bold text-gray-900 dark:text-white">
                                                <span id="counter-depth-max">0 km</span>
                                            </div>
                                        </div>
                                        <div class="text-center">
                                            <div class="text-xs text-gray-600 dark:text-gray-400">Ortalama</div>
                                            <div class="counter-value text-lg font-bold text-gray-900 dark:text-white">
                                                <span id="counter-depth-avg">0 km</span>
                                            </div>
                                        </div>
                                        <div class="text-center">
                                            <div class="text-xs text-gray-600 dark:text-gray-400">Toplam</div>
                                            <div class="counter-value text-lg font-bold text-gray-900 dark:text-white">
                                                <span id="counter-depth-total">0</span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="w-full h-24 bg-gray-100 dark:bg-gray-700 rounded-lg overflow-hidden mt-2">
                                        <canvas id="depthChart"></canvas>
                                    </div>
                                    <div class="text-xs text-gray-500 mt-1 text-center" id="depth-location">En derin: -</div>
                                </div>
                            </div>
                        </div>

                        <div class="stats-card p-6 cursor-pointer" id="active-regions">
                            <div class="flex items-start justify-between">
                                <div class="flex-1">
                                    <div class="icon-container icon-success">
                                        🗺️
                                    </div>
                                    <div class="stats-title">Bölgesel Aktivite</div>
                                    <div class="flex justify-between items-center mb-2">
                                        <div>
                                            <div class="counter-value text-3xl font-bold text-gray-900 mb-1">
                                                <span id="counter-regions">0</span>
                                            </div>
                                            <div class="stats-subtitle">Aktif İl</div>
                                        </div>
                                        <div class="text-right">
                                            <div id="most-active-region" class="text-sm font-semibold text-gray-600">-</div>
                                            <div id="most-active-count" class="text-xs text-gray-500">0 deprem</div>
                                        </div>
                                    </div>
                                    <div class="mt-2">
                                        <div class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">En Aktif 5 Bölge</div>
                                        <div id="top-regions" class="grid grid-cols-1 gap-1">
                                        </div>
                                    </div>
                                    <div class="mt-2 text-xs text-gray-500">
                                        <span id="region-time-range">Son 24 saat</span> içinde
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="stats-card p-6 cursor-pointer" id="nearest-earthquake">
                            <div class="flex items-start justify-between">
                                <div class="flex-1">
                                    <div class="icon-container icon-info">
                                        📍
                                    </div>
                                    <div class="stats-title">En Yakın Deprem</div>
                                    <div class="flex justify-between items-start mb-2 gap-x-4 gap-y-2">
                                        <div>
                                            <div class="counter-value text-3xl font-bold text-gray-900 dark:text-white">
                                                <span id="nearest-magnitude">-</span>
                                            </div>
                                            <div class="stats-subtitle text-gray-600 dark:text-gray-400">Büyüklük</div>
                                        </div>
                                        <div class="text-right">
                                            <div class="flex items-center justify-end gap-1 text-sm font-semibold text-gray-600 dark:text-gray-400">
                                                <span class="text-base">📏</span>
                                                <span id="nearest-distance">-</span>
                                                <span class="text-xs">km</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="space-y-2">
                                        <div class="text-sm">
                                            <span class="text-gray-600 dark:text-gray-400">Yer:</span>
                                            <span id="nearest-location" class="font-medium text-gray-900 dark:text-gray-200 ml-1">-</span>
                                        </div>
                                        <div class="text-sm">
                                            <span class="text-gray-600 dark:text-gray-400">Şehir:</span>
                                            <span id="nearest-city" class="font-medium text-gray-900 dark:text-gray-200 ml-1">-</span>
                                        </div>
                                        <div class="text-sm">
                                            <span class="text-gray-600 dark:text-gray-400">Tarih/Saat:</span>
                                            <span id="nearest-datetime" class="font-medium text-gray-900 dark:text-gray-200 ml-1">-</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-white dark:bg-gray-800 border-t dark:border-gray-700 h-12">
        <div class="max-w-full mx-auto h-full px-4">
            <div class="flex flex-col md:flex-row justify-between items-center h-full">
                <div class="flex flex-col md:flex-row items-center space-y-1 md:space-y-0 md:space-x-2 mb-2 md:mb-0">
                    <span class="text-xs text-gray-500 text-center md:text-left">
                        Bu uygulama açık kaynak bir projedir. Ticari amaçla kullanılamaz.
                    </span>
                    <span class="text-xs text-gray-500 text-center md:text-left">
                        Veriler Kandilli Rasathanesi'nden alınmaktadır.
                    </span>
                    <span class="text-xs text-gray-500 text-center md:text-left">
                        Kullanımdan doğabilecek hiçbir sorumluluk kabul edilmemektedir.
                    </span>
                </div>
                <p class="text-sm text-gray-500 dark:text-gray-400">
                    &copy; 2025 Türkiye Deprem Takip Ekibi | Açık Kaynak Proje
                </p>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script type="text/javascript" src="/assets/js/stats.js"></script>
    <script type="text/javascript" src="/assets/js/app.js"></script>
</body>

</html>